<div id="Content">
   <div id="TopContent">
      <h1>Fast and Easy Tool Rentals</h1>
      <h1>Delivered to your door</h1>
      <p>Rent top-quality tools and equipment without leaving your home</p>

      {{!--
      Once we have a backend fleshed out, this will actual route users to category_xxxxx of the tool / category inputted
      --}}
      <div id="searchBox">
         <input id="searchInput" placeholder="Search tools...">
         <div id="searchButton">
            ?
         </div>
      </div>
   </div>

   <div id="CenterContent">
      <div id="ToolsContent">
         <a href="/category_cleaning">
            <div class="ToolCat">
               <img src="/public/images/RR_Floor_IMG.png" alt="Cleaning tools">
            </div>
         </a>

         <a href="/category_lawn">
            <div class="ToolCat">
               <img src="/public/images/RR_Lawn_IMG.png" alt="Lawn tools">
            </div>
         </a>

         <a href="/category_ladders">
            <div class="ToolCat">
               <img src="/public/images/RR_LaddersLift_IMG.png" alt="Ladders and lifts">
